# ==========================================
# BLUESENSE FULLSTACK PROJECT .gitignore
# React + Node.js + MongoDB + Render/Vercel
# ==========================================

# ======================
# Dependencies
# ======================
node_modules/
**/node_modules/
jspm_packages/
bower_components/

# ======================
# Environment Variables
# ======================
.env
.env.*
!.env.example

# ======================
# Logs
# ======================
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
backend.log

# ======================
# Runtime Data
# ======================
pids
*.pid
*.seed
*.pid.lock

# ======================
# Coverage / Testing
# ======================
coverage/
*.lcov
.nyc_output/

# ======================
# Build Outputs
# ======================

# React / Vite / Frontend
dist/
build/
.next/
out/
.nuxt/
.svelte-kit/

# General caches
.cache/
.parcel-cache/
.temp/

# ======================
# TypeScript
# ======================
*.tsbuildinfo

# ======================
# Package Archives
# ======================
*.tgz
*.zip
*.rar
*.7z

# ======================
# Uploads / User Files
# ======================
backend/uploads/*
!backend/uploads/.gitkeep

# ======================
# Reports / Generated Files
# ======================
backend/reports/*.pdf
backend/reports/*.xlsx
backend/reports/*.csv
backend/reports/*.docx

# ======================
# VS Code / Editors
# ======================
.vscode/
.vscode-test/
.idea/

# ======================
# OS Files
# ======================
.DS_Store
Thumbs.db
desktop.ini

# ======================
# Yarn
# ======================
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# ======================
# Misc
# ======================
.firebase/
.serverless/
.dynamodb/
.tern-port

# ======================
# Diagnostic Reports
# ======================
report.*.json

# ======================
# Vite Timestamp Logs
# ======================
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# ======================
# Keep Important Empty Folders
# ======================
!backend/uploads/.gitkeep